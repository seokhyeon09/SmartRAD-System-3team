# 개발용 Dockerfile
# - 소스 코드를 볼륨 마운트해서 사용하는 것을 전제로 함 (docker-compose.dev.yml 등에서 volumes로 마운트)
# - spring-boot-devtools가 클래스패스 변경을 감지해 자동으로 재시작함
FROM eclipse-temurin:17-jdk-alpine

WORKDIR /app

# gradle wrapper 및 설정 파일 먼저 복사해서 의존성 캐시 레이어 활용
COPY gradlew .
COPY gradle gradle
COPY build.gradle settings.gradle ./

RUN chmod +x ./gradlew

# 의존성 미리 받아두기 (소스 변경 시 매번 새로 받지 않도록)
RUN ./gradlew dependencies --no-daemon || true

# 소스 코드는 compose에서 볼륨으로 덮어씌워지므로 여기서는 최초 빌드용으로만 복사
COPY src src

EXPOSE 8080
# 원격 디버깅을 쓰고 싶으면 아래처럼 5005 포트도 열고 JAVA_TOOL_OPTIONS를 추가하면 됨
# EXPOSE 5005

ENTRYPOINT ["./gradlew", "bootRun", "--no-daemon"]